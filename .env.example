# =============================================================================
# InfraSense Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values before starting the stack:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control. It is listed in .gitignore.
# =============================================================================

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
HTTP_PORT=80
DOMAIN=localhost

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=infrasense
DB_USER=infrasense
DB_PASSWORD=InfraSense@2024
DB_SSL_MODE=disable
TEST_DATABASE_URL=postgres://infrasense:InfraSense@2024@localhost:5432/infrasense_test?sslmode=disable

# Security (JWT_SECRET and ENCRYPTION_KEY must each be exactly 32 characters)
JWT_SECRET=InfraSenseJWTSecret2024XYZ123456
ENCRYPTION_KEY=InfraSenseEncKey2024ABCDE123456!
JWT_EXPIRY=24h

# Admin User (created on first startup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@infrasense.local
ADMIN_PASSWORD=Admin@123456

# Services
VICTORIAMETRICS_URL=http://victoriametrics:8428
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Admin@123456

# Environment
ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Notifications (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_USERNAME=
EMAIL_PASSWORD=
SLACK_WEBHOOK_URL=
